/*
 * gmaio — genome & metagenome all-in-one
 * Main configuration. Containers-only. nf-core-style standalone.
 */

plugins {
    id 'nf-schema@2.1.1'
}

params {
    // --- Core ---
    mode                    = null      // illumina_metagenome | nanopore_metagenome | illumina_isolate | nanopore_isolate | download_dbs
    input                   = null      // samplesheet (CSV)
    outdir                  = 'results'
    publish_dir_mode        = 'copy'
    email                   = null
    monochrome_logs         = false

    // --- Container image base (for bespoke local .sif images) ---
    // e.g. /srv/db/containers locally, or a /scratch path on Bunya. Set per-profile.
    container_base          = null

    // --- Reference databases (default to the /srv/db layout already in use) ---
    gtdbtk_db               = '/srv/db/gtdbtk/official/release226'
    checkm2_db              = '/srv/db/checkm2_data/1.0.2/CheckM2_database'
    checkm1_db              = '/srv/db/checkm1'
    singlem_metapackage     = '/srv/db/singlem_packages/S5.4.0.GTDB_r226.metapackage_20250331.smpkg.zb'
    sylph_db                = '/srv/db/sylph/gtdb-r226'
    bakta_db                = '/srv/db/bakta/6.0/db'
    dram_db                 = '/srv/db/dram'
    genomad_db              = '/srv/db/genomad'
    checkv_db               = '/srv/db/checkv/checkv-db-v1.5'
    eggnog_db               = '/srv/db/eggnog/5.0'
    amrfinder_db            = null      // null => use the db bundled in the amrfinder container
    host_ref                = null      // host genome (fasta) for cleanifier/minimap2 host removal
    cleanifier_db           = null
    genomespot_models       = null      // GenomeSPOT models dir

    // DB download (used only with --mode download_dbs)
    download_db             = null      // comma-list or 'all'
    db_outdir               = 'databases'

    // --- Step toggles (defaults chosen to match the typical full run) ---
    skip_qc                 = false
    skip_sylph              = false
    skip_singlem            = false
    skip_host_removal       = false
    skip_assembly           = false
    skip_binning            = false
    skip_dereplication      = false
    skip_read_mapping       = false
    skip_gene_catalogue     = false
    skip_annotation         = false     // DRAM / bakta
    skip_taxonomy           = false     // GTDB-Tk
    skip_checkm             = false
    skip_mobile_elements    = false     // geNomad/CheckV/clustering
    run_nonpareil           = true
    run_genomespot          = true
    run_checkm1             = true      // in addition to CheckM2

    // --- Tool-choice slots (alternatives) ---
    catalogue_clusterer     = 'cdhit'   // cdhit | mmseqs
    core_alignment          = 'parsnp'  // parsnp | snippy
    tree_builder            = 'iqtree'  // iqtree | raxml

    // --- Generic resource ceilings (overridden per profile) ---
    max_cpus                = 16
    max_memory              = '128.GB'
    max_time                = '72.h'

    // --- Schema validation help ---
    validate_params         = true
    help                    = false
}

// Containers only — Apptainer is the runtime; Docker/conda intentionally off.
apptainer {
    enabled    = true
    autoMounts = true
    // cacheDir is set per-profile (scratch on Bunya, /srv locally).
}
docker.enabled    = false
podman.enabled    = false
conda.enabled     = false
singularity.enabled = false   // we standardise on the `apptainer` scope

// Base resources and per-module directives.
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'
includeConfig 'conf/containers.config'

profiles {
    bunya     { includeConfig 'conf/bunya.config'     }
    bunya_gpu { includeConfig 'conf/bunya.config'; includeConfig 'conf/bunya_gpu.config' }
    local     { includeConfig 'conf/local.config'     }
    test      { includeConfig 'conf/test.config'      }
}

// Reports
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline_${trace_timestamp}.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report_${trace_timestamp}.html" }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace_${trace_timestamp}.txt" }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag_${trace_timestamp}.html" }

manifest {
    name            = 'ace/gmaio'
    author          = 'Julian Zaugg'
    description     = 'Genome & metagenome all-in-one: isolate/metagenome × Illumina/Nanopore'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '0.1.0dev'
}

// Honour `params.max_*` ceilings (nf-core check_max idiom).
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj, params.max_cpus as int) }
        catch (all) { return obj }
    }
}
