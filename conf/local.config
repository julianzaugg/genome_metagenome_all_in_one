/*
 * Local /srv Linux server — single node, local executor.
 * Concurrency is bounded by queueSize and the max_* ceilings (replacing the
 * GNU-parallel `-j` pattern from the bash scripts).
 *
 * EDIT THIS FILE to match your server: resource ceilings and database paths.
 * Container images/cache default to project-local directories.
 */

params {
    max_cpus       = 90
    max_memory     = '470.GB'
    max_time       = '720.h'

    // Where bespoke local .sif images live (dorado, genomespot).
    container_base = "${projectDir}/containers"

    // --- Database locations on this server (override nextflow.config defaults) ---
    gtdbtk_db           = '/srv/db/gtdbtk/official/release232'
    checkm2_db          = '/srv/db/checkm2_data/1.0.2/CheckM2_database'
    checkm1_db          = '/srv/db/checkm1'
    singlem_metapackage = '/srv/db/singlem_packages/S6.5.0.GTDB_r232.metapackage_20260319.smpkg.zb'
    // sylph: a path OR glob of the .syldb file(s) to profile against (you pick
    // which — your /srv/db/sylph holds gtdb-r226, gtdb-r232 and fungi). Examples:
    //   single:  '/srv/db/sylph/gtdb-r232-c200-dbv1.syldb'
    //   several: '/srv/db/sylph/{gtdb-r232,fungi}*.syldb'   (r232 + fungi, not r226)
    sylph_db            = '/srv/db/sylph/gtdb-r232-c200-dbv1.syldb'
    // sylph-tax metadata should match the .syldb file(s) chosen above.
    // For multi-DB runs, pass a matching glob/list on the command line.
    sylph_tax_metadata  = '/srv/db/sylph/gtdb_r232_metadata.tsv.gz'
    bakta_db            = '/srv/db/bakta/6.0/db'
    dram_db             = '/srv/db/DRAM_1.4.6'
    genomad_db          = '/srv/db/genomad/genomad_db_v1.9'
    checkv_db           = '/srv/db/checkv/checkv-db-v1.5'
    eggnog_db           = '/srv/db/eggnog/5.0'

    // Cleanifier k-mer index for host/contaminant removal. Set this to a
    // pre-built .filter index, or set --host_ref to a FASTA to build one.
    host_ref            = null
    cleanifier_db       = null
    cleanifier_nobjects = null

    // GenomeSPOT models dir (only needed if --run_genomespot). Project-specific —
    // set to your models path or pass --genomespot_models.
    // genomespot_models = '/srv/.../GenomeSPOT/models'
}

process {
    executor = 'local'

    // Give the full 90 CPUs to tools that scale well with threads locally.
    withName: 'GTDBTK_CLASSIFYWF|CHECKM2_PREDICT|CHECKM1_LINEAGEWF|AVIARY_RECOVER|SYLPH_PROFILE|GENOMAD_ENDTOEND|CLEANIFIER|RPKM_DIAMOND_MAKEDB|RPKM_DIAMOND_GENE|RPKM_DIAMOND_SINGLEM' {
        cpus   = { check_max( 90, 'cpus' ) }
    }
}

executor {
    cpus        = 90
    memory      = '470.GB'
    queueSize   = 90
}

apptainer {
    cacheDir = "${projectDir}/.apptainer_cache"
}
