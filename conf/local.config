/*
 * Local /srv Linux server — single node, local executor.
 * Concurrency is bounded by queueSize and the max_* ceilings (replacing the
 * GNU-parallel `-j` pattern from the bash scripts).
 *
 * EDIT THIS FILE to match your server: resource ceilings, where .sif images live
 * (container_base), the Apptainer cache, and the database paths below.
 */

params {
    max_cpus       = 90
    max_memory     = '470.GB'
    max_time       = '720.h'

    // Where bespoke local .sif images live (dorado, genomespot, minimap2_samtools).
    container_base = '/srv/db/containers'

    // --- Database locations on this server (override nextflow.config defaults) ---
    gtdbtk_db           = '/srv/db/gtdbtk/official/release226'
    checkm2_db          = '/srv/db/checkm2_data/1.0.2/CheckM2_database'
    checkm1_db          = '/srv/db/checkm1'
    singlem_metapackage = '/srv/db/singlem_packages/S5.4.0.GTDB_r226.metapackage_20250331.smpkg.zb'
    // sylph: a path OR glob of the .syldb file(s) to profile against (you pick
    // which — your /srv/db/sylph holds gtdb-r226, gtdb-r232 and fungi). Examples:
    //   single:  '/srv/db/sylph/gtdb-r226-c200-dbv1.syldb'
    //   several: '/srv/db/sylph/{gtdb-r226,fungi}*.syldb'   (r226 + fungi, not r232)
    sylph_db            = '/srv/db/sylph/gtdb-r226-c200-dbv1.syldb'
    // sylph-tax metadata (taxonomy + merged abundance tables). Should match the
    // .syldb files chosen above; extra metadata is harmless. null = skip taxonomy.
    sylph_tax_metadata  = '/srv/db/sylph/*_metadata.tsv.gz'
    bakta_db            = '/srv/db/bakta/6.0/db'
    dram_db             = '/srv/db/dram'
    genomad_db          = '/srv/db/genomad'
    checkv_db           = '/srv/db/checkv/checkv-db-v1.5'
    eggnog_db           = '/srv/db/eggnog/5.0'

    // Cleanifier k-mer index for host/contaminant removal (required unless
    // --skip_host_removal). Set to your .filter index, e.g.:
    cleanifier_db       = '/srv/db/cleanifier/t2t_pangenome_hla_variants_cdna_cleanifier_index_k29_w33.filter'

    // GenomeSPOT models dir (only needed if --run_genomespot). Project-specific —
    // set to your models path or pass --genomespot_models.
    // genomespot_models = '/srv/.../GenomeSPOT/models'
}

process {
    executor = 'local'
}

executor {
    cpus        = 90
    memory      = '470.GB'
    queueSize   = 90
}

apptainer {
    cacheDir = '/srv/db/apptainer_cache'
}
