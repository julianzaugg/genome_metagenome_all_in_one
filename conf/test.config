/*
 * Minimal test profile — tiny resources + bundled mini samplesheet.
 * Self-contained for `-stub` wiring checks / small CI on a single machine:
 *   nextflow run . -profile test --mode illumina_metagenome -stub
 * (Use this profile ALONE — do not combine with bunya/local, which set HPC paths.)
 */

// Local executor; stub runs do not execute containers so Apptainer is off here.
process.executor = 'local'
apptainer.enabled = false

// nf-core modules capture tool versions with eval() which runs even under -stub.
// Tiny shims satisfy those version commands so a tool-free machine can run stubs.
env.PATH = "${projectDir}/tests/shims:\$PATH"

params {
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '2.h'

    input  = "${projectDir}/assets/samplesheets/illumina_metagenome.csv"
    outdir = 'results_test'

    // Point DBs at the bundled stub placeholders so validation passes offline.
    gtdbtk_db           = "${projectDir}/tests/data/dbs/gtdbtk"
    checkm2_db          = "${projectDir}/tests/data/dbs/checkm2"
    checkm1_db          = "${projectDir}/tests/data/dbs/checkm1"
    singlem_metapackage = "${projectDir}/tests/data/dbs/singlem.smpkg.zb"
    sylph_db            = "${projectDir}/tests/data/dbs/sylph"
    dram_db             = "${projectDir}/tests/data/dbs/dram"
    genomad_db          = "${projectDir}/tests/data/dbs/genomad"
    checkv_db           = "${projectDir}/tests/data/dbs/checkv"
    bakta_db            = "${projectDir}/tests/data/dbs/bakta"
    eggnog_db           = "${projectDir}/tests/data/dbs/eggnog"

    // Lighter run for tests.
    run_nonpareil  = false
    run_genomespot = false
    run_checkm1    = false
}
