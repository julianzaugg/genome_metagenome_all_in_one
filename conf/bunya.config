/*
 * Bunya HPC — SLURM executor (primary target).
 * Confirm account/partition/qos strings for your allocation before a real run.
 */

params {
    max_cpus      = 96
    max_memory    = '470.GB'
    max_time      = '336.h'
    // Local .sif images for bespoke tools live here on Bunya scratch.
    container_base = '/scratch/project/a_ace/containers'
}

process {
    executor       = 'slurm'
    queue          = 'general'
    clusterOptions = '--account=a_ace'
    // SLURM is sometimes slow to register completion; tolerate it.
    maxRetries     = 2
}

executor {
    queueSize      = 100
    submitRateLimit = '10/1min'
    pollInterval   = '30 sec'
}

apptainer {
    cacheDir = '/scratch/project/a_ace/apptainer_cache'
}
