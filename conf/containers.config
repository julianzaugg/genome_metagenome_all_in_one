/*
 * Container assignment (containers-only pipeline).
 *
 *  - Reused nf-core/modules ship their own biocontainer directive (pulled from a
 *    registry and converted by Apptainer). Override any of them with a withName
 *    block here if you want a custom image.
 *  - Bespoke local modules use local .sif images under params.container_base.
 *    Fill in / confirm these images — see docs/containers.md.
 *
 * Paths resolve to "<container_base>/<name>.sif". Edit filenames/URIs to match
 * whatever you actually built.
 */

process {

    // --- Read profiling ---
    withName: 'SYLPH_.*'        { container = "${params.container_base}/sylph_0.9.0.sif" }
    withName: 'SINGLEM_.*'      { container = "${params.container_base}/singlem_0.19.0.sif" }

    // --- QC / host removal ---
    withName: 'FASTPLONG'           { container = "${params.container_base}/fastplong_0.4.1.sif" }
    withName: 'CLEANIFIER'          { container = "${params.container_base}/cleanifier_1.3.0.sif" }
    withName: 'MINIMAP2_HOSTFILTER' { container = "${params.container_base}/minimap2_2.28.sif" }

    // --- Assembly / polishing ---
    withName: 'MYLOASM'         { container = "${params.container_base}/myloasm_0.5.1.sif" }
    withName: 'AUTOCYCLER.*'    { container = "${params.container_base}/autocycler_0.6.1.sif" }
    withName: 'DORADO_.*'       { container = "${params.container_base}/dorado_1.4.0.sif" }
    withName: 'POLYPOLISH'      { container = "${params.container_base}/polypolish_0.6.1.sif" }
    withName: 'DNAAPLER'        { container = "${params.container_base}/dnaapler_1.3.0.sif" }
    withName: 'SHOVILL'         { container = "${params.container_base}/shovill_1.1.0.sif" }

    // --- Binning / coverage ---
    withName: 'AVIARY_.*'       { container = "${params.container_base}/aviary_0.12.0.sif" }
    withName: 'COVERM_.*'       { container = "${params.container_base}/coverm_0.7.0.sif" }

    // --- Gene catalogue / annotation ---
    withName: 'PYRODIGAL'        { container = "${params.container_base}/pyrodigal_3.6.3.sif" }
    withName: 'CDHIT'            { container = "${params.container_base}/cdhit_4.8.1.sif" }
    withName: 'CATALOGUE_PREP'   { container = "${params.container_base}/seqkit_2.8.sif" }
    withName: 'CATALOGUE_TABULATE' { container = "${params.container_base}/python_3.11.sif" }
    withName: 'MMSEQS.*'        { container = "${params.container_base}/mmseqs2_15.sif" }
    withName: 'DRAM_.*'         { container = "${params.container_base}/dram_1.4.6.sif" }

    // --- Genome QC / taxonomy ---
    withName: 'CHECKM1_.*'      { container = "${params.container_base}/checkm1_1.2.3.sif" }
    withName: 'NONPAREIL'       { container = "${params.container_base}/nonpareil_3.4.1.sif" }
    withName: 'GENOMESPOT'      { container = "${params.container_base}/genomespot_1.0.sif" }

    // --- Mobile elements ---
    withName: 'GENOMAD_PROCESS' { container = "${params.container_base}/seqkit_2.8.sif" }
    withName: 'CHECKV_COLLATE'  { container = "${params.container_base}/seqkit_2.8.sif" }
    withName: 'CHECKV_CLUSTER'  { container = "${params.container_base}/checkv_1.0.3.sif" }

    // --- Isolate typing ---
    withName: 'CHEWBACCA_.*'    { container = "${params.container_base}/chewbbaca_3.3.10.sif" }
    withName: 'PARSNP'          { container = "${params.container_base}/parsnp_2.1.4.sif" }
    withName: 'FASTANI'         { container = "${params.container_base}/fastani_1.33.sif" }

    // --- Small utility processes (lightweight image) ---
    withName: 'UTIL_.*'         { container = "${params.container_base}/python_3.11.sif" }
}
