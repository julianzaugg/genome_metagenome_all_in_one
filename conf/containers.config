/*
 * Container assignment (containers-only pipeline).
 *
 *  - Reused nf-core/modules ship their own biocontainer directive — not set here.
 *  - Bespoke local modules point at quay.io biocontainers wherever the tool is
 *    packaged (Apptainer pulls docker://… and caches a .sif — no build needed).
 *  - Only a few genuinely need a local .sif (params.container_base): a tool not
 *    on biocontainers, or a process needing two tools in one image.
 *
 * Build tags were resolved from the quay.io biocontainers API (latest build per
 * pinned version). Bump as needed; or use the galaxyproject mirror to skip the
 * Docker→SIF conversion, e.g.
 *   https://depot.galaxyproject.org/singularity/sylph:0.9.0--ha6fb395_0
 */

process {

    // ===================== quay.io biocontainers =====================

    // Read profiling
    withName: 'SYLPH_SKETCH'    { container = 'quay.io/biocontainers/sylph:0.9.0--ha6fb395_0' }
    withName: 'SYLPH_PROFILE'   { container = 'quay.io/biocontainers/sylph:0.9.0--ha6fb395_0' }
    withName: 'SYLPH_TAX'       { container = 'quay.io/biocontainers/sylph-tax:1.8.0--pyhdfd78af_0' }
    withName: 'SINGLEM_.*'      { container = 'quay.io/biocontainers/singlem:0.21.3--pyhdfd78af_0' }

    // QC (long read) / host removal (single)
    withName: 'PORECHOP'        { container = 'quay.io/biocontainers/porechop:0.2.4--py39h7cff6ad_4' }
    withName: 'FASTPLONG'       { container = 'quay.io/biocontainers/fastplong:0.4.1--h224cc79_0' }
    withName: 'CLEANIFIER.*'    { container = 'quay.io/biocontainers/cleanifier:1.3.0--pyhdfd78af_0' }

    // Assembly / polishing
    withName: 'SHOVILL'         { container = 'quay.io/biocontainers/shovill:1.1.0--hdfd78af_2' }
    withName: 'MYLOASM'         { container = 'quay.io/biocontainers/myloasm:0.5.1--hd612981_1' }
    withName: 'AUTOCYCLER.*'    { container = 'quay.io/biocontainers/autocycler:0.6.1--h79ce301_0' }
    withName: 'POLYPOLISH'      { container = 'quay.io/biocontainers/polypolish:0.6.1--h3ab6199_0' }
    withName: 'DNAAPLER'        { container = 'quay.io/biocontainers/dnaapler:1.3.0--pyhdfd78af_0' }

    // Binning / coverage
    // Aviary 0.13.0 shells out to `pixi run` for its internal Snakemake rules.
    // The quay.io biocontainer carries the CLI but not pixi, so use a local
    // upstream-style image with pixi and prebuilt Aviary environments.
    withName: 'AVIARY_RECOVER'  {
        container = {
            def base = params.containsKey('container_base') && params.container_base ? params.container_base : "${projectDir}/containers"
            params.containsKey('aviary_container') && params.aviary_container ? params.aviary_container : "${base}/aviary_0.13.0.sif"
        }
    }
    withName: 'AVIARY_COLLECT_BINS' { container = 'quay.io/biocontainers/seqkit:2.8.2--h9ee0642_1' }
    withName: 'COVERM_.*'       { container = 'quay.io/biocontainers/coverm:0.7.0--hcb7b614_4' }

    // Gene catalogue / annotation
    withName: 'PYRODIGAL'       { container = 'quay.io/biocontainers/pyrodigal:3.6.3--py312h0fa9677_1' }
    withName: 'CDHIT'           { container = 'quay.io/biocontainers/cd-hit:4.8.1--h5ca1c30_13' }
    withName: 'MMSEQS.*'        { container = 'quay.io/biocontainers/mmseqs2:15.6f452--pl5321h6a68c12_3' }
    withName: 'DRAM_.*'         { container = 'quay.io/biocontainers/dram:1.4.6--pyhdfd78af_2' }
    withName: 'RPKM_DIAMOND_.*' { container = 'quay.io/biocontainers/diamond:2.1.8--h43eeafb_0' }
    withName: 'RPKM_CALCULATE'  { container = 'quay.io/biocontainers/python:3.9--1' }

    // Genome QC
    withName: 'CHECKM1_.*'      { container = 'quay.io/biocontainers/checkm-genome:1.2.3--pyhdfd78af_1' }
    withName: 'NONPAREIL'       { container = 'quay.io/biocontainers/nonpareil:3.5.5--r44h077b44d_2' }
    withName: 'BARRNAP'         { container = 'quay.io/biocontainers/barrnap:0.9--hdfd78af_4' }

    // Mobile elements — CHECKV_CLUSTER runs blast+ plus vendored Python helpers.
    // The standalone blast image lacks Python, so use the CheckV image that
    // carries the original tool stack.
    withName: 'CHECKV_CLUSTER'  { container = 'https://depot.galaxyproject.org/singularity/checkv:1.0.3--pyhdfd78af_0' }

    // Isolate typing / comparative
    withName: 'BAKTA_.*'        { container = 'quay.io/biocontainers/bakta:1.11.0--pyhdfd78af_0' }
    withName: 'MLST'            { container = 'quay.io/biocontainers/mlst:2.23.0--hdfd78af_0' }
    withName: 'AMRFINDERPLUS_.*' { container = 'quay.io/biocontainers/ncbi-amrfinderplus:4.0.22--h5e33c3e_0' }
    withName: 'ISESCAN.*'       { container = 'quay.io/biocontainers/isescan:1.7.2.3--pyhdfd78af_2' }
    withName: 'PANAROO_RUN'     { container = 'quay.io/biocontainers/panaroo:1.5.2--pyhdfd78af_1' }
    withName: 'CHEWBACCA_.*'    { container = 'quay.io/biocontainers/chewbbaca:3.3.10--pyhdfd78af_0' }
    withName: 'PARSNP'          { container = 'quay.io/biocontainers/parsnp:2.1.4--h077b44d_0' }
    withName: 'GUBBINS'         { container = 'quay.io/biocontainers/gubbins:3.4.0--pyhdfd78af_0' }
    withName: 'FASTANI'         { container = 'quay.io/biocontainers/fastani:1.33--h4dfc31f_3' }
    withName: 'IQTREE'          { container = 'quay.io/biocontainers/iqtree:2.3.6--hdbdd923_0' }

    // Shell/fasta glue + python helpers
    withName: 'GENOMAD_PROCESS|CHECKV_COLLATE|PREP_ASSEMBLY|CATALOGUE_PREP|CATALOGUE_CDS|FASTQ_GZIP_TEST|SEQKIT_STATS|RPKM_FILTER_READS|RPKM_SINGLEM_MARKERS|RPKM_PREBUILT_SINGLEM_MARKERS' {
        container = 'quay.io/biocontainers/seqkit:2.8.2--h9ee0642_1'
    }
    withName: 'CATALOGUE_TABULATE|UTIL_.*|PREP_COMPARISON_GROUPS' { container = 'quay.io/biocontainers/python:3.9--1' }

    // ===================== local .sif required =====================
    // Not on biocontainers, or needs two tools in one image. Build/provide these
    // under params.container_base (see docs/containers.md).
    withName: 'DORADO_.*'           {
        container = {
            def base = params.containsKey('container_base') && params.container_base ? params.container_base : "${projectDir}/containers"
            "${base}/dorado_1.4.0.sif"
        }
    }       // ONT, not packaged
    withName: 'GENOMESPOT'          {
        container = {
            def base = params.containsKey('container_base') && params.container_base ? params.container_base : "${projectDir}/containers"
            "${base}/genomespot_1.0.sif"
        }
    }     // not packaged

    // ===================== DB downloaders (--mode download_dbs) =====================
    withName: 'DL_GTDBTK'  { container = 'quay.io/biocontainers/gtdbtk:2.7.2--pyhdfd78af_0' }
    withName: 'DL_CHECKM2' { container = 'quay.io/biocontainers/checkm2:1.0.2--pyh7cba7a3_0' }
    withName: 'DL_GENOMAD' { container = 'quay.io/biocontainers/genomad:1.7.4--pyhdfd78af_0' }
    withName: 'DL_CHECKV'  { container = 'quay.io/biocontainers/checkv:1.0.3--pyhdfd78af_0' }
    withName: 'DL_BAKTA'   { container = 'quay.io/biocontainers/bakta:1.11.0--pyhdfd78af_0' }
    withName: 'DL_DRAM'    { container = 'quay.io/biocontainers/dram:1.4.6--pyhdfd78af_2' }
    withName: 'DL_SINGLEM' { container = 'quay.io/biocontainers/singlem:0.21.3--pyhdfd78af_0' }
}
