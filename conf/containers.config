/*
 * Container assignment (containers-only pipeline).
 *
 *  - Reused nf-core/modules ship their own biocontainer directive — not set here.
 *  - Bespoke local modules: where the tool is a single biocontainer on quay.io,
 *    we point straight at it (Apptainer pulls docker://… and caches a .sif, no
 *    build needed). Where the tool ISN'T on biocontainers, or a process needs
 *    TWO tools in one image, we fall back to a local .sif under
 *    params.container_base — build/provide those (see docs/containers.md).
 *
 * quay build tags below were resolved from the quay.io biocontainers API
 * (latest build per version). Bump them as needed; or swap the registry for the
 * galaxyproject mirror, e.g.
 *   https://depot.galaxyproject.org/singularity/sylph:0.9.0--ha6fb395_0
 */

process {

    // ===== On quay.io biocontainers (no build needed) =====

    // Read profiling
    withName: 'SYLPH_.*'        { container = 'quay.io/biocontainers/sylph:0.9.0--ha6fb395_0' }
    withName: 'SINGLEM_.*'      { container = 'quay.io/biocontainers/singlem:0.19.0--pyhdfd78af_0' }

    // Binning / coverage
    withName: 'COVERM_.*'       { container = 'quay.io/biocontainers/coverm:0.7.0--hcb7b614_4' }

    // Gene catalogue
    withName: 'PYRODIGAL'       { container = 'quay.io/biocontainers/pyrodigal:3.6.3--py312h0fa9677_1' }
    withName: 'CDHIT'           { container = 'quay.io/biocontainers/cd-hit:4.8.1--h5ca1c30_13' }
    withName: 'DRAM_.*'         { container = 'quay.io/biocontainers/dram:1.4.6--pyhdfd78af_2' }

    // Genome QC
    withName: 'CHECKM1_.*'      { container = 'quay.io/biocontainers/checkm-genome:1.2.3--pyhdfd78af_1' }
    withName: 'NONPAREIL'       { container = 'quay.io/biocontainers/nonpareil:3.5.5--r44h077b44d_2' }

    // Shell/fasta glue + python helpers
    withName: 'GENOMAD_PROCESS|CHECKV_COLLATE|PREP_ASSEMBLY|CATALOGUE_PREP' {
        container = 'quay.io/biocontainers/seqkit:2.8.2--h9ee0642_1'
    }
    withName: 'CATALOGUE_TABULATE' { container = 'quay.io/biocontainers/python:3.9--1' }

    // ===== Local .sif required (not a single biocontainer) =====

    // Not on biocontainers / bespoke:
    withName: 'AVIARY_.*'       { container = "${params.container_base}/aviary_0.12.0.sif" }      // complex deps
    withName: 'GENOMESPOT'      { container = "${params.container_base}/genomespot_1.0.sif" }     // not packaged

    // Need TWO tools in one image (build a small combined .sif, or use a mulled image):
    withName: 'MINIMAP2_HOSTFILTER' { container = "${params.container_base}/minimap2_samtools.sif" } // minimap2 + samtools
    withName: 'CHECKV_CLUSTER'      { container = "${params.container_base}/checkv_blast.sif" }      // blast+ + python3

    // ===== Other-mode tools (scaffolds) — fill when those workflows are built =====
    // Most are single biocontainers too (shovill, fastplong, polypolish, dnaapler,
    // chewbbaca, parsnp, fastani); dorado/myloasm/autocycler/cleanifier are bespoke.
    withName: 'FASTPLONG'       { container = "${params.container_base}/fastplong_0.4.1.sif" }
    withName: 'CLEANIFIER'      { container = "${params.container_base}/cleanifier_1.3.0.sif" }
    withName: 'MYLOASM'         { container = "${params.container_base}/myloasm_0.5.1.sif" }
    withName: 'AUTOCYCLER.*'    { container = "${params.container_base}/autocycler_0.6.1.sif" }
    withName: 'DORADO_.*'       { container = "${params.container_base}/dorado_1.4.0.sif" }
    withName: 'POLYPOLISH'      { container = "${params.container_base}/polypolish_0.6.1.sif" }
    withName: 'DNAAPLER'        { container = "${params.container_base}/dnaapler_1.3.0.sif" }
    withName: 'SHOVILL'         { container = "${params.container_base}/shovill_1.1.0.sif" }
    withName: 'MMSEQS.*'        { container = "${params.container_base}/mmseqs2_15.sif" }
    withName: 'CHEWBACCA_.*'    { container = "${params.container_base}/chewbbaca_3.3.10.sif" }
    withName: 'PARSNP'          { container = "${params.container_base}/parsnp_2.1.4.sif" }
    withName: 'FASTANI'         { container = "${params.container_base}/fastani_1.33.sif" }

    // ===== DB downloaders (--mode download_dbs) — reuse each tool's image =====
    withName: 'DL_GTDBTK'  { container = "${params.container_base}/gtdbtk_2.7.2.sif" }
    withName: 'DL_CHECKM2' { container = "${params.container_base}/checkm2_1.0.2.sif" }
    withName: 'DL_GENOMAD' { container = "${params.container_base}/genomad_1.7.4.sif" }
    withName: 'DL_CHECKV'  { container = "${params.container_base}/checkv_1.0.3.sif" }
    withName: 'DL_BAKTA'   { container = "${params.container_base}/bakta_1.11.0.sif" }
    withName: 'DL_DRAM'    { container = 'quay.io/biocontainers/dram:1.4.6--pyhdfd78af_2' }
    withName: 'DL_SINGLEM' { container = 'quay.io/biocontainers/singlem:0.19.0--pyhdfd78af_0' }

    withName: 'UTIL_.*'    { container = 'quay.io/biocontainers/python:3.9--1' }
}
