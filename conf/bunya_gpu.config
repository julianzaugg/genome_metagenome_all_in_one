/*
 * Bunya GPU overlay — attach H100 resources to processes labelled `gpu`
 * (dorado basecalling/polishing). Layered on top of conf/bunya.config:
 *   -profile bunya_gpu
 * Mirrors run_basecaller_bunya.slurm / run_dorado_polish_bunya.slurm.
 */

process {
    withLabel:gpu {
        queue          = 'gpu_cuda'
        clusterOptions = '--account=a_ace --partition=gpu_cuda --qos=gpu --gres=gpu:h100:1'
        // dorado needs the CUDA allocator tweak seen in the example SLURM scripts.
        beforeScript   = 'export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True'
    }
}

apptainer {
    // --nv exposes the GPU to the container.
    runOptions = '--nv'
}
