/*
 * Per-module tool flags (ext.args) and publishDir layout.
 *
 * publishDir mirrors the numbered-directory convention from the bash scripts
 * (e.g. 03_fastp, 06_metaspades, ...) so outputs feel familiar. Tool flags live
 * here — never hard-code them in process bodies — so methods can be tuned
 * without editing modules. `versions.yml` is never published.
 */

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
    ]

    // ----------------------------------------------------------------------
    // QC
    // ----------------------------------------------------------------------
    withName: 'FASTP' {
        ext.args   = '--detect_adapter_for_pe --cut_front --cut_tail --cut_mean_quality 20 --length_required 50'
        publishDir = [ path: { "${params.outdir}/03_fastp" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'FASTPLONG' {
        ext.args   = '--length_required 500 --mean_qual 9'
        publishDir = [ path: { "${params.outdir}/03_fastplong" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'PORECHOP_PORECHOP' {
        ext.args   = '--discard_middle'
        publishDir = [ path: { "${params.outdir}/02_porechop" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Read profiling
    // ----------------------------------------------------------------------
    withName: 'SYLPH_SKETCH'  { publishDir = [ path: { "${params.outdir}/04_sylph" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SYLPH_PROFILE' { publishDir = [ path: { "${params.outdir}/04_sylph" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SINGLEM_PIPE'  { publishDir = [ path: { "${params.outdir}/05_singlem" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Host removal
    // ----------------------------------------------------------------------
    withName: 'CLEANIFIER'          { publishDir = [ path: { "${params.outdir}/06_host_removed" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'MINIMAP2_HOSTFILTER' { publishDir = [ path: { "${params.outdir}/06_host_removed" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Assembly
    // ----------------------------------------------------------------------
    withName: 'SPADES' {
        ext.args   = '--meta'
        publishDir = [ path: { "${params.outdir}/07_metaspades" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'MYLOASM' { publishDir = [ path: { "${params.outdir}/07_myloasm" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SHOVILL' {
        ext.args   = '--assembler spades --minlen 500'
        publishDir = [ path: { "${params.outdir}/07_shovill" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Binning + dereplication + mapping
    // ----------------------------------------------------------------------
    withName: 'AVIARY_RECOVER' { publishDir = [ path: { "${params.outdir}/08_aviary" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'COVERM_CLUSTER' {
        // dereplicate bins at 97% ANI (matches run_bin_dereplication.sh)
        ext.args   = '--precluster-method finch --ani 0.97'
        publishDir = [ path: { "${params.outdir}/09_dereplicated_bins" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_GENOME' {
        ext.args   = '--methods relative_abundance covered_fraction mean count --discard-unmapped --mapper minimap2-sr --min-covered-fraction 0.0 --min-read-percent-identity 0.95 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/10_coverm_bins" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_CONTIG' {
        ext.args   = '--methods covered_fraction mean count --discard-unmapped --mapper minimap2-sr --min-covered-fraction 0.0 --min-read-percent-identity 0.95 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/10_coverm_scaffolds" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Gene catalogue + annotation
    // ----------------------------------------------------------------------
    withName: 'PYRODIGAL' {
        ext.args   = '-p meta'
        publishDir = [ path: { "${params.outdir}/11_pyrodigal" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CDHIT' {
        ext.args   = '-c 1.0 -aS 0.9 -d 0 -M 0 -g 1'
        publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CATALOGUE_PREP'     { publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CATALOGUE_TABULATE' { publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DRAM_ANNOTATE' { publishDir = [ path: { "${params.outdir}/13_dram" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DRAM_DISTILL'  { publishDir = [ path: { "${params.outdir}/13_dram" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Genome taxonomy + QC
    // ----------------------------------------------------------------------
    withName: 'GTDBTK_CLASSIFYWF' {
        ext.args   = '--skip_ani_screen'
        publishDir = [ path: { "${params.outdir}/14_gtdbtk" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CHECKM2_PREDICT'   { publishDir = [ path: { "${params.outdir}/15_checkm2" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKM1_LINEAGEWF' { publishDir = [ path: { "${params.outdir}/15_checkm1" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'NONPAREIL'         { publishDir = [ path: { "${params.outdir}/16_nonpareil" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GENOMESPOT'        { publishDir = [ path: { "${params.outdir}/17_genomespot" },mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Mobile elements (virus/plasmid)
    // ----------------------------------------------------------------------
    withName: 'GENOMAD_ENDTOEND' { publishDir = [ path: { "${params.outdir}/18_genomad" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GENOMAD_PROCESS'  { publishDir = [ path: { "${params.outdir}/18_genomad" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKV_ENDTOEND'  { publishDir = [ path: { "${params.outdir}/19_checkv" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKV_CLUSTER' {
        ext.args   = '--min_ani 95 --min_tcov 85 --min_qcov 0'
        publishDir = [ path: { "${params.outdir}/20_checkv_clustering" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Isolate typing / comparative (isolate workflows)
    // ----------------------------------------------------------------------
    withName: 'BAKTA_BAKTA'       { publishDir = [ path: { "${params.outdir}/10_bakta" },     mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'MLST'              { publishDir = [ path: { "${params.outdir}/11_mlst" },      mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'AMRFINDERPLUS_RUN' { publishDir = [ path: { "${params.outdir}/12_amrfinder" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'ISESCAN'           { publishDir = [ path: { "${params.outdir}/13_isescan" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'PANAROO_RUN' {
        ext.args   = '--clean-mode strict --aligner mafft --core_threshold 0.99 --threshold 0.90 --alignment core --remove-invalid-genes --merge_paralogs'
        publishDir = [ path: { "${params.outdir}/14_panaroo" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'PARSNP'        { ext.args = '-c'; publishDir = [ path: { "${params.outdir}/15_parsnp" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GUBBINS'       { publishDir = [ path: { "${params.outdir}/16_gubbins" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'FASTANI'       { publishDir = [ path: { "${params.outdir}/17_fastani" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHEWBACCA_.*'  { publishDir = [ path: { "${params.outdir}/18_chewbacca" },mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'IQTREE'        { ext.args = '-fast -m GTR'; publishDir = [ path: { "${params.outdir}/19_tree" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // DB downloads (--mode download_dbs) -> params.db_outdir
    // ----------------------------------------------------------------------
    withName: 'DL_.*' {
        publishDir = [ path: { "${params.outdir}/${params.db_outdir}" }, mode: 'copy' ]
    }

    // ----------------------------------------------------------------------
    // Intermediates — not published
    // ----------------------------------------------------------------------
    withName: 'PREP_ASSEMBLY'  { publishDir = [ enabled: false ] }
    withName: 'CHECKV_COLLATE' { publishDir = [ enabled: false ] }

    // ----------------------------------------------------------------------
    // Pipeline meta
    // ----------------------------------------------------------------------
    withName: 'MULTIQC' {
        publishDir = [ path: { "${params.outdir}/99_multiqc" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
}
