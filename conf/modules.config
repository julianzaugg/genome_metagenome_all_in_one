/*
 * Per-module tool flags (ext.args) and publishDir layout.
 *
 * publishDir mirrors the numbered-directory convention from the bash scripts so
 * outputs feel familiar. Numbers run gaplessly in EXECUTION ORDER per mode — they
 * are NOT kept consistent across modes (each mode is a separate run with its own
 * output tree). Shared processes across modes (GTDB-Tk, CheckM, geNomAD,
 * CheckV, CoverM) use mode-aware aliases where needed so each mode stays
 * readable and avoids read-platform-specific argument collisions.
 * Tool flags live here — never hard-code them in process bodies. `versions.yml`
 * is never published.
 */

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
    ]

    // ----------------------------------------------------------------------
    // QC
    // ----------------------------------------------------------------------
    withName: 'FASTP' {
        ext.args   = '--cut_front --cut_tail --cut_mean_quality 20 --length_required 50'
        publishDir = [ path: { "${params.outdir}/01_fastp" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'FASTQ_GZIP_TEST' {
        publishDir = [ enabled: false ]
    }
    withName: 'SEQKIT_STATS' {
        publishDir = [ path: { "${params.outdir}/00_read_stats" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'FASTPLONG' {
        ext.args   = '--length_required 500 --mean_qual 9'
        publishDir = [ path: { "${params.outdir}/03_fastplong" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'PORECHOP' {
        ext.args   = '--discard_middle'
        publishDir = [ path: { "${params.outdir}/02_porechop" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'DORADO_BASECALL' { publishDir = [ path: { "${params.outdir}/01_dorado_basecall" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DORADO_DEMUX'    { publishDir = [ path: { "${params.outdir}/01_dorado_basecall" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Read profiling
    // ----------------------------------------------------------------------
    withName: 'SYLPH_SKETCH'  { publishDir = [ path: { "${params.outdir}/02_sylph" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SYLPH_PROFILE' {
        ext.args = { params.sylph_profile_args ?: '' }
        publishDir = [ path: { "${params.outdir}/02_sylph" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'SYLPH_TAX'     { publishDir = [ path: { "${params.outdir}/02_sylph" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SINGLEM_PIPE'  { publishDir = [ path: { "${params.outdir}/03_singlem" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Host removal
    // ----------------------------------------------------------------------
    withName: 'CLEANIFIER_INDEX' {
        ext.args   = '-k 29 --windowsize 33'
        publishDir = [ path: { "${params.outdir}/04_host_removed/index" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CLEANIFIER' {
        ext.args   = '--compression gz --compression-level 7 --threshold 0.5 --buffersize 20'
        publishDir = [ path: { "${params.outdir}/04_host_removed" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Assembly
    // ----------------------------------------------------------------------
    withName: 'SPADES' {
        // metaSPAdes with the kmer set from run_metaspades.sh.
        // (singletons input from the old trimmomatic step isn't produced by fastp;
        //  add fastp --unpaired output + a 3rd reads file if you want it back.)
        ext.args   = '--meta -k 21,33,55,81,99,127'
        publishDir = [ path: { "${params.outdir}/05_metaspades" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'MYLOASM' { publishDir = [ path: { "${params.outdir}/07_myloasm" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'SHOVILL' {
        ext.args   = '--assembler spades --minlen 500'
        publishDir = [ path: { "${params.outdir}/07_shovill" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'AUTOCYCLER_ASSEMBLE' { publishDir = [ path: { "${params.outdir}/05_autocycler" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DORADO_POLISH'       { publishDir = [ path: { "${params.outdir}/06_dorado_polish" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'POLYPOLISH'          { publishDir = [ path: { "${params.outdir}/07_polypolish" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DNAAPLER'            { publishDir = [ path: { "${params.outdir}/08_dnaapler" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Binning + dereplication + mapping
    // ----------------------------------------------------------------------
    withName: 'AVIARY_RECOVER' {
        // Skip aviary's internal steps that gmaio runs as separate processes.
        // --skip-singlem: gmaio profiles reads via SINGLEM_PIPE before binning.
        // --skip-taxonomy: gmaio runs GTDBTK_CLASSIFYWF on the final bin set.
        // --skip-abundances: gmaio computes coverages via COVERM_GENOME/CLUSTER.
        // Override ext.args to add/remove flags (e.g. --binning-only, --strict).
        ext.args           = '--skip-singlem --skip-taxonomy --skip-abundances'
        ext.long_read_type = { params.aviary_long_read_type ?: 'ont_hq' }
        publishDir = [ path: { "${params.outdir}/06_aviary" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'AVIARY_COLLECT_BINS' { publishDir = [ path: { "${params.outdir}/06_aviary" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'COVERM_CLUSTER' {
        // dereplicate bins at 97% ANI (matches run_bin_dereplication.sh)
        ext.args   = '--precluster-method finch --ani 0.97'
        publishDir = [ path: { "${params.outdir}/08_dereplicated_bins" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_GENOME' {
        ext.args   = '--methods relative_abundance covered_fraction mean count --discard-unmapped --mapper minimap2-sr --min-covered-fraction 0.0 --bam-file-cache-directory . --min-read-percent-identity 0.95 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/09_coverm_bins" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_CONTIG' {
        ext.args   = '--methods covered_fraction mean count --discard-unmapped --mapper minimap2-sr --min-covered-fraction 0.0 --bam-file-cache-directory . --min-read-percent-identity 0.95 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/10_coverm_scaffolds" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_GENOME_ONT' {
        ext.args   = '--methods relative_abundance covered_fraction mean count --discard-unmapped --mapper minimap2-ont --min-covered-fraction 0.0 --bam-file-cache-directory . --min-read-percent-identity 0.90 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/09_coverm_bins" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_CONTIG_ONT' {
        ext.args   = '--methods covered_fraction mean count --discard-unmapped --mapper minimap2-ont --min-covered-fraction 0.0 --bam-file-cache-directory . --min-read-percent-identity 0.90 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/10_coverm_scaffolds_nanopore" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'COVERM_CONTIG_SR' {
        ext.args   = '--methods covered_fraction mean count --discard-unmapped --mapper minimap2-sr --min-covered-fraction 0.0 --bam-file-cache-directory . --min-read-percent-identity 0.95 --min-read-aligned-percent 0.75'
        publishDir = [ path: { "${params.outdir}/10_coverm_scaffolds_illumina" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Gene catalogue + annotation
    // ----------------------------------------------------------------------
    withName: 'PYRODIGAL' {
        ext.args   = '-p meta'
        publishDir = [ path: { "${params.outdir}/11_pyrodigal" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CDHIT' {
        // common cd-hit flags; -c (identity) and -n (word size) are set per identity
        // in the module from params.catalogue_identities.
        ext.args   = '-d 0 -M 80000 -g 1'
        publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CATALOGUE_PREP'     { publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CATALOGUE_CDS'      { publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CATALOGUE_TABULATE' { publishDir = [ path: { "${params.outdir}/12_gene_catalogue" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'DRAM_ANNOTATE' { publishDir = [ path: { "${params.outdir}/13_dram" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // RPKM
    // ----------------------------------------------------------------------
    withName: 'RPKM_FILTER_READS'     { publishDir = [ path: { "${params.outdir}/22_rpkm/filtered_reads" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'RPKM_SINGLEM_MARKERS'  { publishDir = [ path: { "${params.outdir}/22_rpkm/singlem_markers" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'RPKM_PREBUILT_SINGLEM_MARKERS' { publishDir = [ path: { "${params.outdir}/22_rpkm/singlem_markers" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'RPKM_DIAMOND_MAKEDB'   { publishDir = [ enabled: false ] }
    withName: 'RPKM_DIAMOND_GENE' {
        ext.args   = '--evalue 0.00001 --min-score 40 --query-cover 80 --id 70 --max-hsps 1 --max-target-seqs 1'
        publishDir = [ path: { "${params.outdir}/22_rpkm/gene_blast/per_sample" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'RPKM_COLLATE_GENE_BLAST' { publishDir = [ path: { "${params.outdir}/22_rpkm/gene_blast" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'RPKM_DIAMOND_SINGLEM' {
        ext.args   = '--evalue 0.00001 --min-score 40 --query-cover 80 --id 70 --max-hsps 1 --max-target-seqs 1'
        publishDir = [ path: { "${params.outdir}/22_rpkm/singlem_blast" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'RPKM_CALCULATE' { publishDir = [ path: { "${params.outdir}/22_rpkm" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Genome taxonomy + QC
    // ----------------------------------------------------------------------
    withName: 'GTDBTK_CLASSIFYWF' {
        ext.args   = '--extension fasta'
        publishDir = [ path: { "${params.outdir}/14_gtdbtk" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'CHECKM2_PREDICT'   { publishDir = [ path: { "${params.outdir}/07_checkm2" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKM1_LINEAGEWF' { publishDir = [ path: { "${params.outdir}/15_checkm1" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'NONPAREIL'         { publishDir = [ path: { "${params.outdir}/16_nonpareil" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GENOMESPOT'        { publishDir = [ path: { "${params.outdir}/17_genomespot" },mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'BARRNAP'           { publishDir = [ path: { "${params.outdir}/18_barrnap" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // Mobile elements (virus/plasmid)
    // ----------------------------------------------------------------------
    withName: 'GENOMAD_ENDTOEND' { publishDir = [ path: { "${params.outdir}/19_genomad" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GENOMAD_PROCESS'  { publishDir = [ path: { "${params.outdir}/19_genomad" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKV_ENDTOEND'  { publishDir = [ path: { "${params.outdir}/20_checkv" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHECKV_CLUSTER' {
        ext.args   = '--min_ani 95 --min_tcov 85 --min_qcov 0'
        publishDir = [ path: { "${params.outdir}/21_checkv_clustering" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }

    // ----------------------------------------------------------------------
    // Isolate typing / comparative (isolate workflows)
    // ----------------------------------------------------------------------
    withName: 'BAKTA_BAKTA'       { publishDir = [ path: { "${params.outdir}/10_bakta" },     mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'BAKTA_STATS'       { publishDir = [ path: { "${params.outdir}/10_bakta" },     mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'MLST'              { publishDir = [ path: { "${params.outdir}/11_mlst" },      mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'AMRFINDERPLUS_RUN' { publishDir = [ path: { "${params.outdir}/12_amrfinder" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'AMRFINDERPLUS_COLLATE' { publishDir = [ path: { "${params.outdir}/12_amrfinder" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'ISESCAN'           { publishDir = [ path: { "${params.outdir}/13_isescan" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'ISESCAN_COLLATE'   { publishDir = [ path: { "${params.outdir}/13_isescan" },   mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'PREP_COMPARISON_GROUPS' { publishDir = [ path: { "${params.outdir}/14_comparison_groups" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'PANAROO_RUN' {
        ext.args   = '--clean-mode strict --aligner mafft --core_threshold 0.99 --threshold 0.90 --alignment core --remove-invalid-genes --merge_paralogs'
        publishDir = [ path: { "${params.outdir}/14_panaroo" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ]
    }
    withName: 'PARSNP'        { ext.args = '-c'; publishDir = [ path: { "${params.outdir}/15_parsnp" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'GUBBINS'       { publishDir = [ path: { "${params.outdir}/16_gubbins" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'FASTANI'       { publishDir = [ path: { "${params.outdir}/17_fastani" },  mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'CHEWBACCA_.*'  { publishDir = [ path: { "${params.outdir}/18_chewbacca" },mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }
    withName: 'IQTREE'        { ext.args = '-fast -m GTR'; publishDir = [ path: { "${params.outdir}/19_tree" }, mode: params.publish_dir_mode, saveAs: { fn -> fn.equals('versions.yml') ? null : fn } ] }

    // ----------------------------------------------------------------------
    // DB downloads (--mode download_dbs) -> params.db_outdir
    // ----------------------------------------------------------------------
    withName: 'DL_.*' {
        publishDir = [ path: { "${params.outdir}/${params.db_outdir}" }, mode: 'copy' ]
    }

    // ----------------------------------------------------------------------
    // Intermediates — not published
    // ----------------------------------------------------------------------
    withName: 'PREP_ASSEMBLY'  { publishDir = [ enabled: false ] }
    withName: 'CHECKV_COLLATE' { publishDir = [ enabled: false ] }

}
