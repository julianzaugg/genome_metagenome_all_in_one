/*
 * Base resource directives. Each request scales with task.attempt and is capped
 * by `resourceLimits` against the per-profile params.max_cpus / max_memory /
 * max_time ceilings (Nextflow applies the cap automatically).
 */

process {
    resourceLimits = { [ cpus: params.max_cpus, memory: params.max_memory, time: params.max_time ] }

    cpus   = { 1    * task.attempt }
    memory = { 6.GB * task.attempt }
    time   = { 4.h  * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    withLabel:process_single {
        cpus   = { 1 }
        memory = { 4.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 4     * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 6.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 12    * task.attempt }
        memory = { 64.GB * task.attempt }
        time   = { 12.h  * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 24     * task.attempt }
        memory = { 128.GB * task.attempt }
        time   = { 24.h   * task.attempt }
    }
    // Assembly / Aviary / autocycler: memory-bound, long-running.
    withLabel:process_maxmem {
        cpus   = { 32     * task.attempt }
        memory = { 470.GB * task.attempt }
        time   = { 72.h   * task.attempt }
    }
    withLabel:process_long {
        time   = { 48.h * task.attempt }
    }
    // CPU-heavy steps that need many cores but not extreme memory.
    withLabel:process_high_cpu {
        cpus   = { 90 }
        memory = { 64.GB * task.attempt }
        time   = { 24.h  * task.attempt }
    }
    // GPU steps (dorado). bunya_gpu.config attaches the SLURM gres/partition.
    withLabel:gpu {
        cpus   = { 16 }
        memory = { 80.GB }
        time   = { 24.h }
    }

    withLabel:error_ignore { errorStrategy = 'ignore' }
    withLabel:error_retry  { errorStrategy = 'retry'; maxRetries = 2 }
}
