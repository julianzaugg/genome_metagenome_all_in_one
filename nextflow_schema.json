{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/ace/gmaio/main/nextflow_schema.json",
    "title": "gmaio pipeline parameters",
    "description": "Genome & metagenome all-in-one: isolate/metagenome x Illumina/Nanopore",
    "type": "object",
    "defs": {
        "core": {
            "title": "Core options",
            "type": "object",
            "required": ["mode"],
            "properties": {
                "mode": {
                    "type": "string",
                    "enum": ["illumina_metagenome", "nanopore_metagenome", "illumina_isolate", "nanopore_isolate", "download_dbs"],
                    "description": "Which track workflow to run."
                },
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "mimetype": "text/csv",
                    "schema": "assets/schema_input.json",
                    "description": "Path to the samplesheet CSV (not required for --mode download_dbs)."
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "Output directory.",
                    "default": "results"
                },
                "publish_dir_mode": {
                    "type": "string",
                    "default": "copy",
                    "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"],
                    "hidden": true
                },
                "email": { "type": "string", "hidden": true },
                "monochrome_logs": { "type": "boolean", "hidden": true }
            }
        },
        "containers": {
            "title": "Containers",
            "type": "object",
            "properties": {
                "container_base": {
                    "type": "string",
                    "description": "Directory holding local .sif images for bespoke tools (set per-profile)."
                }
            }
        },
        "databases": {
            "title": "Reference databases",
            "type": "object",
            "description": "Paths to pre-built databases. Override per profile, or build with --mode download_dbs.",
            "properties": {
                "gtdbtk_db":           { "type": "string", "description": "GTDB-Tk reference data dir (GTDBTK_DATA_PATH)." },
                "checkm2_db":          { "type": "string", "description": "CheckM2 database dir (CHECKM2_DATA_PATH)." },
                "checkm1_db":          { "type": "string", "description": "CheckM1 database dir." },
                "singlem_metapackage": { "type": "string", "description": "SingleM metapackage (SINGLEM_METAPACKAGE_PATH)." },
                "sylph_db":            { "type": "string", "description": "Sylph database — path or glob of the .syldb file(s) to profile against." },
                "sylph_tax_metadata":  { "type": "string", "description": "sylph-tax metadata path/glob matching the selected sylph_db files; set to enable taxonomy + merge." },
                "bakta_db":            { "type": "string", "description": "Bakta database dir." },
                "dram_db":             { "type": "string", "description": "DRAM database dir." },
                "genomad_db":          { "type": "string", "description": "geNomad database dir." },
                "checkv_db":           { "type": "string", "description": "CheckV database dir." },
                "eggnog_db":           { "type": "string", "description": "eggNOG data dir (EGGNOG_DATA_DIR)." },
                "amrfinder_db":        { "type": "string", "description": "AMRFinderPlus DB dir (null = use container's bundled DB)." },
                "host_ref":            { "type": "string", "description": "Host reference FASTA used to build a Cleanifier index when cleanifier_db is not supplied." },
                "cleanifier_db":       { "type": "string", "description": "Pre-built Cleanifier .filter index. If unset, host_ref is indexed with cleanifier index." },
                "cleanifier_nobjects": { "type": "integer", "description": "Optional -n/--nobjects override for cleanifier index; defaults to estimated FASTA bases." },
                "genomespot_models":   { "type": "string", "description": "GenomeSPOT models directory." },
                "download_db":         { "type": "string", "description": "Comma-list of DB names or 'all' (only with --mode download_dbs)." },
                "db_outdir":           { "type": "string", "default": "databases", "description": "Where --mode download_dbs writes." }
            }
        },
        "steps": {
            "title": "Step toggles",
            "type": "object",
            "properties": {
                "skip_qc":              { "type": "boolean" },
                "skip_sylph":           { "type": "boolean" },
                "skip_singlem":         { "type": "boolean" },
                "skip_host_removal":    { "type": "boolean" },
                "skip_assembly":        { "type": "boolean" },
                "skip_binning":         { "type": "boolean" },
                "skip_dereplication":   { "type": "boolean" },
                "skip_read_mapping":    { "type": "boolean" },
                "skip_gene_catalogue":  { "type": "boolean" },
                "skip_rpkm":            { "type": "boolean" },
                "skip_annotation":      { "type": "boolean" },
                "skip_taxonomy":        { "type": "boolean" },
                "skip_checkm":          { "type": "boolean" },
                "skip_mobile_elements": { "type": "boolean" },
                "run_nonpareil":        { "type": "boolean", "default": true },
                "run_genomespot":       { "type": "boolean", "default": true },
                "run_barrnap":          { "type": "boolean", "default": true },
                "run_checkm1":          { "type": "boolean", "default": true }
            }
        },
        "tool_choice": {
            "title": "Tool-choice slots",
            "type": "object",
            "properties": {
                "catalogue_clusterer": { "type": "string", "enum": ["cdhit", "mmseqs"], "default": "cdhit" },
                "catalogue_identities": { "type": "string", "default": "1.0,0.9", "description": "Comma-separated CD-HIT identities; first is the primary catalogue (used for CDS/membership/DRAM)." },
                "rpkm_min_read_length": { "type": "integer", "default": 140, "description": "Minimum selected R1 read length retained for RPKM DIAMOND blastx." },
                "core_alignment":      { "type": "string", "enum": ["parsnp", "snippy"], "default": "parsnp" },
                "tree_builder":        { "type": "string", "enum": ["iqtree", "raxml"], "default": "iqtree" }
            }
        },
        "resources": {
            "title": "Resource ceilings",
            "type": "object",
            "properties": {
                "max_cpus":   { "type": "integer", "default": 16 },
                "max_memory": { "type": "string", "default": "128.GB", "pattern": "^\\d+(\\.\\d+)?\\.?\\s*(K|M|G|T)?B$" },
                "max_time":   { "type": "string", "default": "72.h", "pattern": "^(\\d+(\\.\\d+)?\\.?\\s*(s|m|h|d|day)\\s*)+$" }
            }
        },
        "generic": {
            "title": "Generic",
            "type": "object",
            "properties": {
                "validate_params": { "type": "boolean", "default": true, "hidden": true },
                "help":            { "type": "boolean", "hidden": true }
            }
        }
    },
    "allOf": [
        { "$ref": "#/defs/core" },
        { "$ref": "#/defs/containers" },
        { "$ref": "#/defs/databases" },
        { "$ref": "#/defs/steps" },
        { "$ref": "#/defs/tool_choice" },
        { "$ref": "#/defs/resources" },
        { "$ref": "#/defs/generic" }
    ]
}
