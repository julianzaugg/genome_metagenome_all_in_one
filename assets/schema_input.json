{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/ace/gmaio/main/assets/schema_input.json",
    "title": "gmaio samplesheet",
    "description": "One row per sample. Required columns depend on --mode and are additionally checked at runtime in the input_check subworkflow.",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and contain no spaces",
                "meta": ["id"]
            },
            "group": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Group must contain no spaces",
                "meta": ["group"]
            },
            "fastq_1": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                "errorMessage": "fastq_1 must be a path to a gzipped FASTQ (.fastq.gz / .fq.gz)"
            },
            "fastq_2": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                "errorMessage": "fastq_2 must be a path to a gzipped FASTQ (.fastq.gz / .fq.gz)"
            },
            "long_reads": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                "errorMessage": "long_reads must be a path to a gzipped FASTQ (.fastq.gz / .fq.gz)"
            },
            "pod5_dir": {
                "type": "string",
                "format": "directory-path",
                "exists": true,
                "errorMessage": "pod5_dir must be a path to a directory of POD5 files (for dorado basecalling)"
            },
            "host_ref": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "errorMessage": "host_ref must be a path to a host reference FASTA"
            }
        },
        "required": ["sample"]
    }
}
