nextflow_pipeline {

    name "illumina_metagenome (stub)"
    script "main.nf"

    test("illumina_metagenome stub run completes and produces numbered outputs") {

        options "-stub"

        when {
            params {
                mode   = "illumina_metagenome"
                input  = "${projectDir}/assets/samplesheets/illumina_metagenome.csv"
                outdir = "$outputDir"
                skip_host_removal = true
            }
        }

        then {
            assert workflow.success
            // key stages were scheduled
            assert workflow.trace.tasks().any { it.name.contains('SEQKIT_STATS') }
            assert workflow.trace.tasks().any { it.name.contains('FASTP') }
            assert workflow.trace.tasks().any { it.name.contains('SPADES') }
            assert workflow.trace.tasks().any { it.name.contains('COVERM_CONTIG') }
            assert workflow.trace.tasks().any { it.name.contains('CHECKV_CLUSTER') }
            assert workflow.trace.tasks().any { it.name.contains('RPKM_CALCULATE') }
            // numbered output dirs exist
            assert path("$outputDir/00_read_stats").exists()
            assert path("$outputDir/01_fastp").exists()
            assert path("$outputDir/10_coverm_scaffolds").exists()
            assert path("$outputDir/12_gene_catalogue").exists()
            assert path("$outputDir/22_rpkm").exists()
            assert path("$outputDir/22_rpkm/singlem_sample_rpkm.tsv").exists()
            assert path("$outputDir/22_rpkm/singlem_rpkm_means.tsv").exists()
            assert path("$outputDir/22_rpkm/gene_catalogue_rpkm_per_gene_normalised.tsv").exists()
            assert path("$outputDir/22_rpkm/gene_catalogue_mapped_reads_per_gene.tsv").exists()
        }
    }
}
